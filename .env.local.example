# Discord OAuth App
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Usuarios permitidos (Discord usernames con #tag, IDs, o emails separados por coma)
# Ejemplo: DarkLord#1234,ShadowKing#5678,123456789012345678
DISCORD_ALLOWED_USERS=tu_username#1234,otro_username#5678

# NextAuth Secret (genera uno con: openssl rand -base64 32)
NEXTAUTH_SECRET=your_random_secret_key_here
NEXTAUTH_URL=http://localhost:3000

# Base de datos
DATABASE_URL=your_neon_database_url
