# GitHub OAuth App
GITHUB_ID=your_github_oauth_app_id
GITHUB_SECRET=your_github_oauth_app_secret

# GitHub Personal Access Token (con permisos de repo)
GITHUB_TOKEN=your_github_personal_access_token

# Repositorio en formato: username/repo-name
GITHUB_REPO=devluchops/website-sc-mafia-clan

# Usuarios permitidos (emails o usernames separados por coma)
GITHUB_ALLOWED_USERS=tu_email@example.com,tu_username

# NextAuth Secret (genera uno con: openssl rand -base64 32)
NEXTAUTH_SECRET=your_random_secret_key_here
NEXTAUTH_URL=http://localhost:3000

# Público (para el cliente)
NEXT_PUBLIC_GITHUB_REPO=devluchops/website-sc-mafia-clan
